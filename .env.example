# ============================================
# Naukri Automation Bot - Environment Variables
# ============================================
# Copy this file to .env and fill in values:
#   cp .env.example .env

# Naukri Credentials (used by npm run fast for quick testing)
NAUKRI_EMAIL=
NAUKRI_PASSWORD=

# SMTP Email Notifications (Gmail: use an App Password, not your real password)
# Generate App Password: myaccount.google.com → Security → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TO=romeshjainofficial@gmail.com

# Encryption (auto-generated on first run via `npm run setup`)
ENCRYPTION_KEY=

# Timezone
TIMEZONE=Asia/Kolkata

# Naukri URLs
NAUKRI_HOME_URL=https://www.naukri.com/
NAUKRI_PROFILE_URL=https://www.naukri.com/mnjuser/profile

# Execution Windows (IST - 24-hour format)
UPDATE_WINDOW_START=9
UPDATE_WINDOW_END=12
UPLOAD_WINDOW_START=10
UPLOAD_WINDOW_END=11

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY_MS=2000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/naukri_bot.log

# Browser Configuration
HEADLESS=true
SLOW_MO=100

# User Agent (realistic browser fingerprint)
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
